{ 6 RANDOM 1 + dv = dv dc SETSPOTSTATE }
{ dc GETSPOTSTATE dv = } lck NOT IFELSE
dv dt += dd dv 1 - GET 1 + dd dv 1 - PUT
} [ 1 2 3 4 5 ] FOREACH
"[ " { ITOA + " " + } dd FOREACH
" ]" & dd =
{ "@105,268 )applause !YAHTZEE!!" ROOMMSG
btt GLOBAL 0 btt =
} dd "5" SUBSTR IF
}
