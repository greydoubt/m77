;Door id 3 Back Button
ON SELECT {
cpr GLOBAL
prar GLOBAL
prar EXEC proparray =
cpr --
{ proparray LENGTH 1 - cpr = } cpr -1 <= IF
proparray cpr GET SETPROPS
"Avatar " cpr 1 + ITOA + "/" + proparray LENGTH ITOA + LOGMSG
}
