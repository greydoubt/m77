# ============================================================================
# GopherAgent environment template
# Fill only what your deployment uses.
# ============================================================================

# ==== Core LLM providers (auto-discovered by constructors) ==================
OPENAI_API_KEY="sk-..."
ANTHROPIC_API_KEY="sk-ant-..."
GEMINI_API_KEY="AIza..."

# ==== OpenAI-compatible providers (passed manually to NewOpenAICompatProvider)
# These are optional convenience vars for your app config.
# Examples:
#   baseURL: https://api.groq.com/openai/v1
#   baseURL: http://localhost:11434/v1 (Ollama)
#   baseURL: http://localhost:8000/v1 (vLLM)
OPENAI_COMPAT_API_KEY=""
OPENAI_COMPAT_BASE_URL=""
OPENAI_COMPAT_MODEL=""

# Provider-specific optional aliases (if your app maps them):
GROQ_API_KEY=""
TOGETHER_API_KEY=""
FIREWORKS_API_KEY=""
OLLAMA_API_KEY="ollama"

# ==== Built-in tools =========================================================
# pkg/tools/builtin/websearch.go
TAVILY_API_KEY="tvly-..."

# ==== SQL / DB ===============================================================
# Used by SQLAgentTool and MySQL session backend.
MYSQL_DSN="user:password@tcp(localhost:3306)/analytics_db?parseTime=true"

# ==== Runtime / app-level knobs (optional, app-owned) =======================
AGENT_LOG_LEVEL="info"
AGENT_SESSION_TTL="30m"
AGENT_CLEANUP_INTERVAL="5m"
AGENT_MAX_ITERS="15"
AGENT_MAX_TOKEN_BUDGET="0"
